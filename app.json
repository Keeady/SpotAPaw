{
  "expo": {
    "name": "SpotAPaw",
    "slug": "SpotAPaw",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/spotapaw-icon.png",
    "scheme": "spotapaw",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bcamaria.SpotAPaw",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Turning on your location will allow us to show you nearby pet sightings.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationUsageDescription": "Turning on your location will allow us to show you nearby pet sightings.",
        "NSPhotoLibraryUsageDescription": "Allow access to photos to upload a photo from your library.",
        "NSCameraUsageDescription": "Allow access to camera to snap a photo of a lost pet."
      },
      "usesAppleSignIn": true
    },
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "CAMERA_ROLL",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/spotapaw-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.bcamaria.SpotAPaw"
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/images/spotapaw-icon.png"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/spotapaw-text-logo-v2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow SpotAPaw to use your location."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SpotAPaw to access your photos.",
          "cameraPermission": "Allow SpotAPaw to use your camera."
        }
      ],
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
